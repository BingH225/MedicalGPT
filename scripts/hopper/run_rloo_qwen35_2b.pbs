#!/bin/bash
#PBS -N medgpt_rloo_q35_2b
#PBS -q auto
#PBS -P CFP03-CF-035
#PBS -l select=1:ncpus=20:ngpus=1:mem=240gb
#PBS -l walltime=10:00:00
#PBS -j oe
#PBS -o /scratch/e1561245/cot_yz/medicalgpt/output/hopper/pbs_logs/

set -euo pipefail

SCRIPT_DIR=/scratch/e1561245/cot_yz/medicalgpt/scripts/hopper
source "${SCRIPT_DIR}/common_env.sh"

ensure_common_dirs
module load "${APPTAINER_MODULE}"
normalize_cuda_visible_devices

RUN_DIR="${OUTPUT_ROOT}/rloo_${PBS_JOBID}"
ADAPTER_DIR="${RUN_DIR}/adapter"
SFT_MERGED_DIR="${ARTIFACT_ROOT}/merged/sft-qwen35-2b"
RM_MERGED_DIR="${ARTIFACT_ROOT}/merged/rm-qwen35-2b"
MERGED_DIR="${ARTIFACT_ROOT}/merged/rloo-qwen35-2b"
BIND_PATHS="$(apptainer_bind_paths)"

mkdir -p "${RUN_DIR}" "${ARTIFACT_ROOT}/merged"
nvidia-smi > "${RUN_DIR}/nvidia_smi.txt"
printf "[INFO] stage=rloo\n[INFO] job_id=%s\n[INFO] run_dir=%s\n[INFO] start_time=%s\n" \
  "${PBS_JOBID}" "${RUN_DIR}" "$(date -Iseconds)" | tee -a "${RUN_DIR}/meta.log"

apptainer exec --nv --bind "${BIND_PATHS}" "${IMAGE_SIF}" bash -lc "
set -euo pipefail
$(container_env_exports)
source '${VENV_DIR}/bin/activate'
cd '${PROJECT_ROOT}'
python -u training/ppo_training.py \
  --sft_model_path '${SFT_MERGED_DIR}' \
  --reward_model_path '${RM_MERGED_DIR}' \
  --model_name_or_path '${SFT_MERGED_DIR}' \
  --use_peft \
  --lora_target_modules q_proj v_proj \
  --lora_r 8 \
  --lora_alpha 16 \
  --lora_dropout 0.05 \
  --dtype float16 \
  --fp16 \
  --train_file_dir '${HOPPER_SFT_DATA_DIR}' \
  --validation_file_dir '${HOPPER_SFT_DATA_DIR}' \
  --max_source_length 512 \
  --max_completion_length 256 \
  --per_device_train_batch_size 1 \
  --gradient_accumulation_steps 4 \
  --gradient_checkpointing True \
  --learning_rate 1e-5 \
  --do_train \
  --max_steps '${RLOO_MAX_STEPS}' \
  --output_dir '${ADAPTER_DIR}' \
  --eval_strategy steps \
  --eval_steps 20 \
  --save_steps 40 \
  --num_train_epochs 1 \
  --report_to tensorboard \
  --dataset_num_proc 1
" > "${RUN_DIR}/train.log" 2>&1

"${SCRIPT_DIR}/run_merge_in_container.sh" \
  "${SFT_MERGED_DIR}" \
  "${SFT_MERGED_DIR}" \
  "${ADAPTER_DIR}" \
  "${MERGED_DIR}" > "${RUN_DIR}/merge.log" 2>&1

printf "[INFO] merged_dir=%s\n[INFO] end_time=%s\n" "${MERGED_DIR}" "$(date -Iseconds)" | tee -a "${RUN_DIR}/meta.log"
echo "run_dir=${RUN_DIR}"
